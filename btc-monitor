# Helper: Extract IP from addr (supports IPv4 "1.2.3.4:8333" and IPv6 "[2001:db8::1]:8333")
extract_ip_from_addr() {
    local addr="$1"
    # If it's in the form [IPv6]:port
    if [[ "$addr" =~ ^\[(.*)\]:(.*)$ ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi
    # If there's a colon, determine whether it's IPv4:port or bare IPv6
    if [[ "$addr" == *:* ]]; then
        # Count colons; if >1 and no brackets, assume bare IPv6 without port
        local colon_count
        colon_count=$(echo "$addr" | awk -F':' '{print NF-1}')
        if [[ "$colon_count" -gt 1 ]]; then
            echo "$addr"
            return 0
        fi
        # IPv4:port → take part before the first colon
        echo "${addr%%:*}"
        return 0
    fi
    # No colon → already just an IP
    echo "$addr"
}

# Cached country lookup with multi-source fallbacks
get_country_info_cached() {
    local ip="$1"
    local bitcoin_dir="/Users/bermekbukair/bitcoin"
    local cache_file="$bitcoin_dir/peer_country_cache.txt"
    mkdir -p "$bitcoin_dir"

    # Check cache first
    local cached_code=""
    if [[ -f "$cache_file" ]]; then
        cached_code=$(awk -F'|' -v key="$ip" '$1==key {print $2; exit}' "$cache_file" 2>/dev/null)
    fi
    if [[ -n "$cached_code" ]]; then
        echo "$cached_code"
        return 0
    fi

    # Use existing function (ipinfo → ip-api) first
    local code
    code=$(get_country_info "$ip")

    # Tertiary fallback: ipwho.is
    if [[ -z "$code" || "$code" == "null" ]]; then
        local r3
        r3=$(curl -s --connect-timeout 3 --max-time 5 "https://ipwho.is/$ip" 2>/dev/null)
        if [[ -n "$r3" ]] && echo "$r3" | jq . > /dev/null 2>&1; then
            code=$(echo "$r3" | jq -r '.country_code // empty')
        fi
    fi

    # Save and return
    if [[ -n "$code" ]]; then
        echo "$ip|$code" >> "$cache_file"
        echo "$code"
        return 0
    fi

    echo ""
}

