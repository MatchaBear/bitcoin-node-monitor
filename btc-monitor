fetch_fx_rates() {
    local fx_data
    # Use cache if less than 10 minutes old
    if [[ -f "$FX_CACHE_FILE" ]]; then
        local cache_age=$(( $(date +%s) - $(stat -f%m "$FX_CACHE_FILE" 2>/dev/null || echo 0) ))
        if [[ $cache_age -lt 600 ]]; then
            cat "$FX_CACHE_FILE"
            return 0
        fi
    fi
    fx_data=$(curl -s --connect-timeout 5 --max-time 10 "https://api.frankfurter.app/latest?from=USD&to=EUR,GBP,SGD,CHF,JPY,KRW,IDR" 2>/dev/null)
    if [[ -n "$fx_data" ]] && echo "$fx_data" | jq -e '.rates.EUR' >/dev/null 2>&1; then
        echo "$fx_data" > "$FX_CACHE_FILE"
        echo "$fx_data"
        return 0
    fi
    # Return cached data even if stale
    [[ -f "$FX_CACHE_FILE" ]] && cat "$FX_CACHE_FILE" && return 0
    # Ultimate fallback - empty (callers handle this)
    echo '{}'
}

