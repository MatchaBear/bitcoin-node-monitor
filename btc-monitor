# Function to format the delta for the last 30 seconds
format_delta30() {
    local current="$1"
    local previous="$2"
    local symbol="$3"

    # Check if previous value is valid
    if [[ -z "$previous" || "$previous" == "0" || "$previous" == "null" ]]; then
        echo -e "Δ~30s: ${WHITE}New data${NC}"
        return
    fi

    local delta
    delta=$(echo "$current - $previous" | bc -l 2>/dev/null || echo "0")
    local delta_sign=$(echo "$delta" | grep -o '^-')

    # Buat nilai absolute untuk tampilan
    clean_delta=$(echo "$delta" | sed 's/^[-+]//')
    formatted_delta=$(printf "%'.2f" "$clean_delta")

    # Hitung persentase tetap untuk info (with zero division check)
    local pct=0
    local abs_pct=0
    if [[ "$previous" != "0" && ! -z "$previous" ]]; then
        pct=$(echo "scale=6; ($delta / $previous) * 100" | bc -l 2>/dev/null || echo "0")
        abs_pct=$(echo "$pct" | sed 's/^[-+]//' 2>/dev/null || echo "0")
    fi
    formatted_pct=$(printf "%.2f" "$pct" 2>/dev/null || echo "0.00")
    formatted_abs_pct=$(printf "%.2f" "$abs_pct" 2>/dev/null || echo "0.00")

    # Warna berdasarkan delta absolut (naik/turun harga)
    if [[ -z "$delta_sign" ]]; then
        echo -e "Δ~30s: ${GREEN}▲ +${formatted_pct}% (${symbol}${formatted_delta}) ${NC}"
    elif [[ "$delta_sign" == "-" ]]; then
        echo -e "Δ~30s: ${RED}▼ −${formatted_abs_pct}% (${symbol}${formatted_delta}) ${NC}"
    else
        echo -e "Δ~30s: ${WHITE}${formatted_pct}% (${symbol}${formatted_delta}) ${NC}"
    fi
}

    # Display all currencies with consistent formatting and provider info
    prev_usd_price=$(read_previous_price "USD")
    delta_usd=$(format_delta30 "$usd_price" "$prev_usd_price" "\$")
    echo -e "USD: ${WHITE}\$$(printf "%'15.2f" "$usd_price")${NC} $(format_change "$usd_change_pct" "$usd_change_raw" "\$") ${CYAN}($USD_PROVIDER)${NC} $delta_usd"

    prev_eur_price=$(read_previous_price "EUR")
    delta_eur=$(format_delta30 "$eur_price" "$prev_eur_price" "€")
    echo -e "EUR: ${WHITE}€$(printf "%'15.2f" "$eur_price")${NC} $(format_change "$eur_change_pct" "$eur_change_raw" "€") ${CYAN}($EUR_PROVIDER)${NC} $delta_eur"

    prev_gbp_price=$(read_previous_price "GBP")
    delta_gbp=$(format_delta30 "$gbp_price" "$prev_gbp_price" "£")
    echo -e "GBP: ${WHITE}£$(printf "%'15.2f" "$gbp_price")${NC} $(format_change "$gbp_change_pct" "$gbp_change_raw" "£") ${CYAN}($GBP_PROVIDER)${NC} $delta_gbp"

    prev_sgd_price=$(read_previous_price "SGD")
    delta_sgd=$(format_delta30 "$sgd_price" "$prev_sgd_price" "S\$") 
    echo -e "SGD: ${WHITE}S\$$(printf "%'14.2f" "$sgd_price")${NC} $(format_change "$sgd_change_pct" "$sgd_change_raw" "S\$") ${CYAN}($SGD_PROVIDER)${NC} $delta_sgd"

    prev_chf_price=$(read_previous_price "CHF")
    delta_chf=$(format_delta30 "$chf_price" "$prev_chf_price" "CHF")
    echo -e "CHF: ${WHITE}CHF$(printf "%'13.2f" "$chf_price")${NC} $(format_change "$chf_change_pct" "$chf_change_raw" "CHF") ${CYAN}($CHF_PROVIDER)${NC} $delta_chf"

    prev_jpy_price=$(read_previous_price "JPY")
    delta_jpy=$(format_delta30 "$jpy_price" "$prev_jpy_price" "¥")
    echo -e "JPY: ${WHITE}¥$(printf "%'15.0f" "$jpy_price")${NC} $(format_change "$jpy_change_pct" "$jpy_change_raw" "¥") ${CYAN}($JPY_PROVIDER)${NC} $delta_jpy"

    prev_krw_price=$(read_previous_price "KRW")
    delta_krw=$(format_delta30 "$krw_price" "$prev_krw_price" "₩")
    echo -e "KRW: ${WHITE}₩$(printf "%'15.0f" "$krw_price")${NC} $(format_change "$krw_change_pct" "$krw_change_raw" "₩") ${CYAN}($KRW_PROVIDER)${NC} $delta_krw"

    prev_idr_price=$(read_previous_price "IDR")
    delta_idr=$(format_delta30 "$idr_price" "$prev_idr_price" "IDR")
    echo -e "IDR: ${WHITE}IDR$(printf "%'13.0f" "$idr_price")${NC} $(format_change "$idr_change_pct" "$idr_change_raw" "IDR") ${CYAN}($IDR_PROVIDER)${NC} $delta_idr"

   else
    echo -e "${RED}❌ Price APIs currently unavailable${NC}"
    echo -e "${YELLOW}💡 This may be due to rate limiting or network issues${NC}"
fi
echo

# Write current prices to file so we can track changes every 30 seconds
write_current_prices

# ATH Section (separate)
echo -e "${BOLD}${PURPLE}📊 ALL-TIME HIGH (ATH)${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
# Get ATH data with bulletproof system
ath_data=$(fetch_bulletproof_ath)
if [[ ! -z "$ath_data" ]] && echo "$ath_data" | jq . > /dev/null 2>&1; then
    # Use persistent cache as fallback instead of hardcoded values
    local c_usd=$(get_cached_ath "usd") c_eur=$(get_cached_ath "eur") c_gbp=$(get_cached_ath "gbp")
    local c_sgd=$(get_cached_ath "sgd") c_chf=$(get_cached_ath "chf") c_jpy=$(get_cached_ath "jpy")
    local c_krw=$(get_cached_ath "krw") c_idr=$(get_cached_ath "idr")
    usd_ath=$(echo "$ath_data" | jq -r ".market_data.ath.usd // ${c_usd:-0}")
    eur_ath=$(echo "$ath_data" | jq -r ".market_data.ath.eur // ${c_eur:-0}")
    gbp_ath=$(echo "$ath_data" | jq -r ".market_data.ath.gbp // ${c_gbp:-0}")
    sgd_ath=$(echo "$ath_data" | jq -r ".market_data.ath.sgd // ${c_sgd:-0}")
    chf_ath=$(echo "$ath_data" | jq -r ".market_data.ath.chf // ${c_chf:-0}")
    jpy_ath=$(echo "$ath_data" | jq -r ".market_data.ath.jpy // ${c_jpy:-0}")
    krw_ath=$(echo "$ath_data" | jq -r ".market_data.ath.krw // ${c_krw:-0}")
    idr_ath=$(echo "$ath_data" | jq -r ".market_data.ath.idr // ${c_idr:-0}")
    
    # Check if ATH was updated and get source
    ath_updated=$(echo "$ath_data" | jq -r '.market_data.ath_updated // false')
    ath_source=$(echo "$ath_data" | jq -r '.market_data.ath_source // "CoinGecko"')
    
    # Get ATH dates if available
    usd_ath_date=$(echo "$ath_data" | jq -r '.market_data.ath_date_formatted.usd // ""')
    eur_ath_date=$(echo "$ath_data" | jq -r '.market_data.ath_date_formatted.eur // ""')
    sgd_ath_date=$(echo "$ath_data" | jq -r '.market_data.ath_date_formatted.sgd // ""')
    idr_ath_date=$(echo "$ath_data" | jq -r '.market_data.ath_date_formatted.idr // ""')
    
    # Display ATH values with update indicator
    ath_indicator=""
    if [[ "$ath_updated" == "true" ]]; then
        ath_indicator="${GREEN}🔥 NEW ATH! ${NC}"
    fi
    
    # Format ATH display with dates for main currencies
    if [[ ! -z "$usd_ath_date" && "$usd_ath_date" != "null" ]]; then
        echo -e "USD: ${YELLOW}\$$(printf "%'15.2f" "$usd_ath")${NC} $ath_indicator ${WHITE}($usd_ath_date)${NC}"
    else
        echo -e "USD: ${YELLOW}\$$(printf "%'15.2f" "$usd_ath")${NC} $ath_indicator"
    fi
    
    if [[ ! -z "$eur_ath_date" && "$eur_ath_date" != "null" ]]; then
        echo -e "EUR: ${YELLOW}€$(printf "%'15.2f" "$eur_ath")${NC} ${WHITE}($eur_ath_date)${NC}"
    else
        echo -e "EUR: ${YELLOW}€$(printf "%'15.2f" "$eur_ath")${NC}"
    fi
    
    echo -e "GBP: ${YELLOW}£$(printf "%'15.2f" "$gbp_ath")${NC}"
    
    if [[ ! -z "$sgd_ath_date" && "$sgd_ath_date" != "null" ]]; then
        echo -e "SGD: ${YELLOW}S\$$(printf "%'14.2f" "$sgd_ath")${NC} ${WHITE}($sgd_ath_date)${NC}"
    else
        echo -e "SGD: ${YELLOW}S\$$(printf "%'14.2f" "$sgd_ath")${NC}"
    fi
    
    echo -e "CHF: ${YELLOW}CHF$(printf "%'13.2f" "$chf_ath")${NC}"
    echo -e "JPY: ${YELLOW}¥$(printf "%'15.0f" "$jpy_ath")${NC}"
    echo -e "KRW: ${YELLOW}₩$(printf "%'15.0f" "$krw_ath")${NC}"
    
    if [[ ! -z "$idr_ath_date" && "$idr_ath_date" != "null" ]]; then
        echo -e "IDR: ${YELLOW}IDR$(printf "%'13.0f" "$idr_ath")${NC} ${WHITE}($idr_ath_date)${NC}"
    else
        echo -e "IDR: ${YELLOW}IDR$(printf "%'13.0f" "$idr_ath")${NC}"
    fi
    
    echo -e "${CYAN}📡 ATH Source: $ath_source${NC}"
else
    echo -e "${RED}❌ ATH data unavailable${NC}"
fi
echo

# Supply Section (optimized, no external script call)
echo -e "${BOLD}${BLUE}⚡ SUPPLY INFO${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [ ! -z "$blocks" ]; then
    # Calculate supply efficiently
    current_height=$blocks
    max_supply=21000000
    halving_interval=210000
    current_era=$((current_height / halving_interval))
    current_reward=$(echo "scale=8; 50 / (2 ^ $current_era)" | bc)
    
    # Simple supply calculation
    total_supply=0
    temp_height=$current_height
    reward=50
    
    for ((i=0; i<$current_era; i++)); do
        total_supply=$(echo "$total_supply + ($halving_interval * $reward)" | bc)
        reward=$(echo "scale=8; $reward / 2" | bc)
        temp_height=$((temp_height - halving_interval))
    done
    
    total_supply=$(echo "$total_supply + ($temp_height * $reward)" | bc)
    remaining=$(echo "$max_supply - $total_supply" | bc)
    percent_mined=$(echo "scale=6; $total_supply * 100 / $max_supply" | bc)
    
    # Next halving
    next_halving=$(( ((current_height/halving_interval)+1)*halving_interval ))
    blocks_to_halving=$((next_halving - current_height))
    days_to_halving=$((blocks_to_halving * 10 / 1440))
    
    echo -e "Current Supply: ${WHITE}$(printf "%'.0f" "$total_supply")${NC} BTC (${percent_mined}%)"
    echo -e "Remaining: ${WHITE}$(printf "%'.0f" "$remaining")${NC} BTC"
    echo -e "Block Reward: ${WHITE}$current_reward${NC} BTC"
    echo -e "Next Halving: ${YELLOW}$(printf "%'d" $blocks_to_halving)${NC} blocks (~$(printf "%'d" $days_to_halving) days)"
else
    echo -e "${RED}❌ Supply data unavailable${NC}"
fi
echo

# Network Hashrate & Difficulty Section
echo -e "${BOLD}${PURPLE}⛏  NETWORK & NODE STATS${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

mining_info=$(docker exec bitcoin-node bitcoin-cli -rpcuser="$RPC_USER" -rpcpassword="$RPC_PASS" getmininginfo 2>/dev/null)
net_totals=$(docker exec bitcoin-node bitcoin-cli -rpcuser="$RPC_USER" -rpcpassword="$RPC_PASS" getnettotals 2>/dev/null)
node_uptime=$(docker exec bitcoin-node bitcoin-cli -rpcuser="$RPC_USER" -rpcpassword="$RPC_PASS" uptime 2>/dev/null)

if [[ -n "$mining_info" ]] && echo "$mining_info" | jq -e '.difficulty' >/dev/null 2>&1; then
    difficulty=$(echo "$mining_info" | jq -r '.difficulty')
    hashrate_raw=$(echo "$mining_info" | jq -r '.networkhashps')

    # Format hashrate to EH/s (exahashes)
    hashrate_eh=$(echo "scale=2; $hashrate_raw / 1000000000000000000" | bc 2>/dev/null)
    # Format difficulty to T (trillions)
    difficulty_t=$(echo "scale=2; $difficulty / 1000000000000" | bc 2>/dev/null)

    echo -e "Hashrate:   ${WHITE}${hashrate_eh} EH/s${NC}"
    echo -e "Difficulty: ${WHITE}${difficulty_t} T${NC}"

    # Estimate next difficulty adjustment
    # Adjustment happens every 2016 blocks
    current_block=$blocks
    last_adjustment=$(( (current_block / 2016) * 2016 ))
    next_adjustment=$(( last_adjustment + 2016 ))
    blocks_until_adj=$(( next_adjustment - current_block ))
    echo -e "Next Diff Adj: ${YELLOW}${blocks_until_adj}${NC} blocks (~$(( blocks_until_adj * 10 / 1440 )) days)"
fi

# Node uptime
if [[ -n "$node_uptime" && "$node_uptime" =~ ^[0-9]+$ ]]; then
    uptime_days=$(( node_uptime / 86400 ))
    uptime_hours=$(( (node_uptime % 86400) / 3600 ))
    uptime_mins=$(( (node_uptime % 3600) / 60 ))
    echo -e "Node Uptime: ${GREEN}${uptime_days}d ${uptime_hours}h ${uptime_mins}m${NC}"
fi

# Bandwidth usage
if [[ -n "$net_totals" ]] && echo "$net_totals" | jq -e '.totalbytesrecv' >/dev/null 2>&1; then
    recv_bytes=$(echo "$net_totals" | jq -r '.totalbytesrecv')
    sent_bytes=$(echo "$net_totals" | jq -r '.totalbytessent')
    recv_gb=$(echo "scale=2; $recv_bytes / 1073741824" | bc 2>/dev/null)
    sent_mb=$(echo "scale=1; $sent_bytes / 1048576" | bc 2>/dev/null)
    echo -e "Bandwidth:  ${CYAN}▼${NC} ${WHITE}${recv_gb} GB${NC} recv | ${CYAN}▲${NC} ${WHITE}${sent_mb} MB${NC} sent"
fi

# Disk Usage for Pruned Mode
bitcoin_data_dir="/Users/bermekbukair/bitcoin/data"
if [[ -d "$bitcoin_data_dir" ]]; then
    blocks_size=$(du -sm "$bitcoin_data_dir/blocks/" 2>/dev/null | awk '{print $1}')
    chainstate_size=$(du -sm "$bitcoin_data_dir/chainstate/" 2>/dev/null | awk '{print $1}')
    total_data_size=$(du -sm "$bitcoin_data_dir" 2>/dev/null | awk '{print $1}')
    prune_limit_mb=10000

    blocks_gb=$(echo "scale=1; ${blocks_size:-0} / 1024" | bc 2>/dev/null)
    chainstate_mb=${chainstate_size:-0}
    total_gb=$(echo "scale=1; ${total_data_size:-0} / 1024" | bc 2>/dev/null)
    prune_pct=$(echo "scale=0; ${blocks_size:-0} * 100 / $prune_limit_mb" | bc 2>/dev/null)

    # Color based on how close to prune limit
    if [[ ${prune_pct:-0} -ge 95 ]]; then
        disk_color=$RED
    elif [[ ${prune_pct:-0} -ge 80 ]]; then
        disk_color=$YELLOW
    else
        disk_color=$GREEN
    fi

    echo -e "Disk Usage: ${disk_color}${blocks_gb} GB${NC} blocks (${prune_pct}% of ${prune_limit_mb}MB prune limit)"
    echo -e "            ${WHITE}${chainstate_mb} MB${NC} chainstate | ${WHITE}${total_gb} GB${NC} total"
fi
echo

    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${WHITE}🔄 Auto-refresh in 30s | Press ${BOLD}Ctrl+C${NC}${WHITE} to exit${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    sleep 30
done

