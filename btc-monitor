save_ath_cache() {
    local usd_ath="$1" source="$2"
    local ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
    jq -n \
        --arg usd "$usd_ath" \
        --arg eur "$(echo "$usd_ath * $FX_EUR" | bc | cut -d. -f1)" \
        --arg gbp "$(echo "$usd_ath * $FX_GBP" | bc | cut -d. -f1)" \
        --arg sgd "$(echo "$usd_ath * $FX_SGD" | bc | cut -d. -f1)" \
        --arg chf "$(echo "$usd_ath * $FX_CHF" | bc | cut -d. -f1)" \
        --arg jpy "$(echo "$usd_ath * $FX_JPY" | bc | cut -d. -f1)" \
        --arg krw "$(echo "$usd_ath * $FX_KRW" | bc | cut -d. -f1)" \
        --arg idr "$(echo "$usd_ath * $FX_IDR" | bc | cut -d. -f1)" \
        --arg src "$source" \
        --arg ts "$ts" \
        '{usd:($usd|tonumber),eur:($eur|tonumber),gbp:($gbp|tonumber),sgd:($sgd|tonumber),chf:($chf|tonumber),jpy:($jpy|tonumber),krw:($krw|tonumber),idr:($idr|tonumber),source:$src,updated:$ts}' \
        > "$ATH_CACHE_FILE"
}

