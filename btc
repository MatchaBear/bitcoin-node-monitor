#!/bin/bash

# Bitcoin Node Monitor - Simple Launcher
# Easy-to-use commands for all monitoring functions
# Version: 3.0.0

# Colors for better user experience
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly PURPLE='\033[0;35m'
readonly CYAN='\033[0;36m'
readonly WHITE='\033[1;37m'
readonly BOLD='\033[1m'
readonly NC='\033[0m'

# Script directory
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Set environment for libraries
export BITCOIN_PROJECT_ROOT="$SCRIPT_DIR"

# Display welcome banner
show_banner() {
    echo -e "${BOLD}${YELLOW}"
    echo "в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—"
    echo "в•‘       рџџ  Bitcoin Node Monitor        в•‘"
    echo "в•‘         Professional Edition         в•‘"
    echo "в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ"
    echo -e "${NC}"
}

# Show help menu
show_help() {
    show_banner
    echo -e "${CYAN}Available Commands:${NC}"
    echo
    echo -e "${GREEN}рџ“Љ Monitoring Commands:${NC}"
    echo -e "  ${BOLD}btc test${NC}        - Test all libraries (safe to run anytime)"
    echo -e "  ${BOLD}btc peers${NC}       - Show connected peers with countries"
    echo -e "  ${BOLD}btc monitor${NC}     - Full monitoring dashboard (requires Bitcoin node)"
    echo
    echo -e "${BLUE}рџ› пёЏ  Utility Commands:${NC}"
    echo -e "  ${BOLD}btc status${NC}      - Quick system status check"
    echo -e "  ${BOLD}btc help${NC}        - Show this help menu"
    echo -e "  ${BOLD}btc version${NC}     - Show version information"
    echo
    echo -e "${PURPLE}рџ’Ў Examples:${NC}"
    echo -e "  ${YELLOW}btc test${NC}       ${CYAN}# Test if everything is working${NC}"
    echo -e "  ${YELLOW}btc peers${NC}      ${CYAN}# See where your Bitcoin peers are from${NC}"
    echo -e "  ${YELLOW}btc monitor${NC}    ${CYAN}# Start full monitoring dashboard${NC}"
    echo
    echo -e "${WHITE}рџ’» Quick Start:${NC}"
    echo -e "  1. Run ${YELLOW}btc test${NC} first to verify everything works"
    echo -e "  2. Run ${YELLOW}btc peers${NC} to see network connections"
    echo -e "  3. Run ${YELLOW}btc monitor${NC} for full monitoring (if Bitcoin node is running)"
    echo
}

# Test function
run_test() {
    echo -e "${CYAN}рџ§Є Testing Bitcoin Monitor Libraries...${NC}"
    echo
    
    if [[ -f "$SCRIPT_DIR/test-libraries.sh" ]]; then
        "$SCRIPT_DIR/test-libraries.sh"
    else
        echo -e "${RED}вќЊ Test script not found!${NC}"
        return 1
    fi
}

# Peers function
run_peers() {
    echo -e "${CYAN}рџЊђ Checking Bitcoin Network Peers...${NC}"
    echo
    
    if [[ -f "$SCRIPT_DIR/peers.sh" ]]; then
        "$SCRIPT_DIR/peers.sh"
    else
        echo -e "${RED}вќЊ Peers script not found!${NC}"
        return 1
    fi
}

# Monitor function
run_monitor() {
    echo -e "${CYAN}рџ“Љ Starting Bitcoin Node Monitor...${NC}"
    echo -e "${YELLOW}Press Ctrl+C to stop monitoring${NC}"
    echo
    
    if [[ -f "$SCRIPT_DIR/btc-monitor-simple.sh" ]]; then
        "$SCRIPT_DIR/btc-monitor-simple.sh"
    elif [[ -f "$SCRIPT_DIR/btc-monitor-professional.sh" ]]; then
        "$SCRIPT_DIR/btc-monitor-professional.sh"
    else
        echo -e "${RED}вќЊ Monitor script not found!${NC}"
        return 1
    fi
}

# Status function
run_status() {
    echo -e "${CYAN}вљЎ Bitcoin Monitor System Status${NC}"
    echo -e "${CYAN}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${NC}"
    echo
    
    # Check if required files exist
    local all_good=true
    
    echo -e "${WHITE}рџ“Ѓ Checking Files:${NC}"
    
    # Check libraries
    if [[ -f "$SCRIPT_DIR/lib/currency_manager.sh" ]]; then
        echo -e "  вњ… Currency Manager Library"
    else
        echo -e "  вќЊ Currency Manager Library missing"
        all_good=false
    fi
    
    if [[ -f "$SCRIPT_DIR/lib/node_info.sh" ]]; then
        echo -e "  вњ… Node Info Library"
    else
        echo -e "  вќЊ Node Info Library missing"
        all_good=false
    fi
    
    # Check configurations
    if [[ -f "$SCRIPT_DIR/config/currencies.json" ]]; then
        echo -e "  вњ… Currency Configuration"
    else
        echo -e "  вќЊ Currency Configuration missing"
        all_good=false
    fi
    
    if [[ -f "$SCRIPT_DIR/config/node_info.json" ]]; then
        echo -e "  вњ… Node Info Configuration"
    else
        echo -e "  вќЊ Node Info Configuration missing"
        all_good=false
    fi
    
    # Check scripts
    if [[ -f "$SCRIPT_DIR/test-libraries.sh" ]]; then
        echo -e "  вњ… Test Script"
    else
        echo -e "  вќЊ Test Script missing"
        all_good=false
    fi
    
    if [[ -f "$SCRIPT_DIR/peers.sh" ]]; then
        echo -e "  вњ… Peers Script"
    else
        echo -e "  вќЊ Peers Script missing"
        all_good=false
    fi
    
    if [[ -f "$SCRIPT_DIR/btc-monitor-professional.sh" ]]; then
        echo -e "  вњ… Professional Monitor Script"
    else
        echo -e "  вќЊ Professional Monitor Script missing"
        all_good=false
    fi
    
    echo
    echo -e "${WHITE}рџ”§ System Status:${NC}"
    
    # Check dependencies
    if command -v jq >/dev/null 2>&1; then
        echo -e "  вњ… jq (JSON processor)"
    else
        echo -e "  вќЊ jq not installed (required for JSON processing)"
        all_good=false
    fi
    
    if command -v curl >/dev/null 2>&1; then
        echo -e "  вњ… curl (HTTP client)"
    else
        echo -e "  вќЊ curl not installed (required for API calls)"
        all_good=false
    fi
    
    if command -v bc >/dev/null 2>&1; then
        echo -e "  вњ… bc (calculator)"
    else
        echo -e "  вќЊ bc not installed (required for calculations)"
        all_good=false
    fi
    
    if command -v docker >/dev/null 2>&1; then
        echo -e "  вњ… docker (container runtime)"
        
        # Check if Bitcoin container is running
        if docker ps | grep -q "bitcoin-node"; then
            echo -e "  вњ… Bitcoin node container running"
        else
            echo -e "  вљ пёЏ  Bitcoin node container not running"
            echo -e "     ${YELLOW}Note: Some features require a running Bitcoin node${NC}"
        fi
    else
        echo -e "  вќЊ docker not installed (required for Bitcoin node)"
        all_good=false
    fi
    
    echo
    if [[ "$all_good" == true ]]; then
        echo -e "${GREEN}рџЋ‰ System Status: All Good!${NC}"
        echo -e "${CYAN}рџ’Ў Run 'btc test' to verify functionality${NC}"
    else
        echo -e "${RED}вљ пёЏ  System Status: Issues Found${NC}"
        echo -e "${YELLOW}рџ’Ў Please fix missing components before using${NC}"
    fi
    echo
}

# Version function
show_version() {
    show_banner
    echo -e "${WHITE}Version Information:${NC}"
    echo -e "  Bitcoin Node Monitor: ${GREEN}v3.0.0${NC}"
    echo -e "  Architecture: ${CYAN}Professional Library-based${NC}"
    echo -e "  Author: ${PURPLE}Bitcoin Node Monitor Project${NC}"
    echo -e "  License: ${YELLOW}MIT${NC}"
    echo
    echo -e "${CYAN}Libraries:${NC}"
    echo -e "  вЂў Currency Manager v3.0.0"
    echo -e "  вЂў Node Info Manager v3.0.0"
    echo
    echo -e "${CYAN}Features:${NC}"
    echo -e "  вЂў Dynamic currency support (8 currencies)"
    echo -e "  вЂў Live country detection (50+ countries)"
    echo -e "  вЂў Intelligent API caching"
    echo -e "  вЂў Multi-tier fallback system"
    echo -e "  вЂў Professional error handling"
    echo
}

# Main command handler
main() {
    case "${1:-help}" in
        "test")
            run_test
            ;;
        "peers")
            run_peers
            ;;
        "monitor")
            run_monitor
            ;;
        "status")
            run_status
            ;;
        "version")
            show_version
            ;;
        "help"|"--help"|"-h"|"")
            show_help
            ;;
        *)
            echo -e "${RED}вќЊ Unknown command: $1${NC}"
            echo -e "${YELLOW}рџ’Ў Run 'btc help' to see available commands${NC}"
            exit 1
            ;;
    esac
}

# Run main function with all arguments
main "$@"
