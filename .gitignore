# Bitcoin Monitoring Tools - .gitignore

# Sensitive information
credentials.txt
config/*.conf
config/bitcoin.conf
**/rpcauth.*
**/*password*
**/*credential*
.env
*.key
*.pem
*.cert

# Bitcoin node data
data/
blocks/
chainstate/
databases/
indexes/
wallets/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo
.DS_Store
btc_last_prices.txt
last_ip.txt
peer_country_cache.txt
cache/*.json

# IDE and editor files
.idea/
.vscode/
*.sublime*
*~
*.bak
*-backup-*
*.pre-upgrade-backup-*

# Docker related
.docker/
docker-data/

# System files
*.pid
*.sock
